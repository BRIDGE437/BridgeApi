{
  "ConnectionStrings": {
    "DefaultConnection": "User ID=postgres;Password=CHANGE_ME;Host=localhost;Port=5432;Database=BridgeApiDb"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "BridgeApi",
    "Audience": "BridgeApi",
    "SecurityKey": "CHANGE_ME_MIN_32_CHARS_SECRET_KEY",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "GoogleAuth": {
    "ClientId": "CHANGE_ME"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "BridgeApi:"
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "UserApi": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    }
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "BasePath": "uploads",
      "BaseUrl": "https://localhost:7065/uploads"
    },
    "S3": {
      "BucketName": "bridgeapi-files",
      "Region": "eu-central-1",
      "AccessKey": "",
      "SecretKey": "",
      "BaseUrl": "https://bridgeapi-files.s3.eu-central-1.amazonaws.com"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  }
}
